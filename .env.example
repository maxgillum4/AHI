# AHI Diagnostic Reasoning Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Optional: Anthropic API key for McKinsey-voice LLM narrative synthesis.
# If not set, the engine uses high-quality template-based synthesis (demo mode).
ANTHROPIC_API_KEY=sk-ant-...

# Server config (defaults shown)
# AHI_HOST=0.0.0.0
# AHI_PORT=8001

# SQLite database path (defaults to ahi.db in the project root)
# AHI_DB_PATH=/path/to/custom/ahi.db
